# Environment Configuration — Riichi Mahjong Calculator
# Copy this file to .env and fill in your values.

# ── Application ───────────────────────────────────────────────────────────
APP_ENV=development          # development | production

# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=riichi_calc
DB_USERNAME=root
DB_PASSWORD=

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=debug              # debug | info | notice | warning | error | critical
# LOG_PATH=/absolute/path/to/storage/logs/app.log  # default: storage/logs/app.log

# ── CORS ──────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGIN=*
CORS_ALLOW_METHODS=GET, POST, OPTIONS
CORS_ALLOW_HEADERS=Content-Type, Authorization, X-Requested-With
CORS_MAX_AGE=3600

# ── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_STORAGE=/absolute/path/to/storage/rate_limit

# ── Authentication ────────────────────────────────────────────────────────
AUTH_ENABLED=false           # Set to true to enforce Bearer token auth
AUTH_STRATEGY=static         # static | db
AUTH_STATIC_TOKEN=           # Required when AUTH_STRATEGY=static
# AUTH_PUBLIC_ROUTES=/api/health,/api/docs
